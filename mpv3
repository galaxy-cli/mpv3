#!/bin/bash
#                         _____ 
#    _ __ ___  _ ____   _|___ / 
#   | '_ ` _ \| '_ \ \ / / |_ \ 
#   | | | | | | |_) \ V / ___) |
#   |_| |_| |_| .__/ \_/ |____/ 
#             |_|               
#
# mpv3 - Text-to-speech and playback utility using Festival, LAME, and MPV
#
# Project: https://github.com

# --- PROGRAM CONFIGURATION ---
PROGRAM_NAME="${0##*/}"
VERSION="1.2.0"

# --- DEPENDENCY CHECK ---
missing=()
for cmd in festival xsel lame mpv; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        missing+=("$cmd")
    fi
done

if [ "${#missing[@]}" -gt 0 ]; then
    echo "${PROGRAM_NAME}: missing required dependencies: ${missing[*]}" >&2
    read -rp "Would you like to install them via apt? [Y/n] " yn
    yn=${yn:-Y}

    if [[ $yn =~ ^[Yy]$ ]]; then
        sudo apt update && sudo apt install -y "${missing[@]}"
    else
        echo "${PROGRAM_NAME}: cannot continue without required dependencies" >&2
        exit 1
    fi
fi

# --- USAGE ---
usage() {
    cat <<EOF
Usage: ${PROGRAM_NAME} [OPTION]... [FILE | TEXT]

Convert text from files, strings, or the clipboard into MP3 audio for instant 
playback and optional permanent saving with fluid sentence pacing.

Mandatory arguments to long options are mandatory for short options too.
  -c, --clipboard        read text directly from the system clipboard
  -f, --file=FILE        read text from specified plaintext FILE
  -s, --speak=TEXT       speak the provided quoted string of TEXT
      --help             display this help and exit
  -v, --version          output version information and exit

Examples:
  ${PROGRAM_NAME} -c
  ${PROGRAM_NAME} -f document.txt
  ${PROGRAM_NAME} -s "Hello world"

Report bugs to: <207926666+galaxy-cli@users.noreply.github.com>
EOF
}

# --- VERSION ---
show_version() {
    cat <<EOF
${PROGRAM_NAME} ${VERSION}
EOF
}

# --- INITIALIZE ---
input_source=""
file_name=""
text=""

# --- ARGUMENT PARSING ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        -c|--clipboard)
            [[ -n "$input_source" ]] && { echo "${PROGRAM_NAME}: multiple input sources specified" >&2; exit 1; }
            input_source="clipboard"
            shift
            ;;
        -f|--file)
            [[ -n "$input_source" ]] && { echo "${PROGRAM_NAME}: multiple input sources specified" >&2; exit 1; }
            [[ -z "$2" || "$2" == -* ]] && { echo "${PROGRAM_NAME}: option requires an argument -- 'f'" >&2; exit 1; }
            input_source="file"
            file_name="$2"
            shift 2
            ;;
        -s|--speak)
            [[ -n "$input_source" ]] && { echo "${PROGRAM_NAME}: multiple input sources specified" >&2; exit 1; }
            [[ -z "$2" || "$2" == -* ]] && { echo "${PROGRAM_NAME}: option requires an argument -- 's'" >&2; exit 1; }
            input_source="string"
            text="$2"
            shift 2
            ;;
        --help)
            usage
            exit 0
            ;;
        -v|--version)
            show_version
            exit 0
            ;;
        -*)
            echo "${PROGRAM_NAME}: unrecognized option '$1'" >&2
            echo "Try '${PROGRAM_NAME} --help' for more information" >&2
            exit 1
            ;;
        *)
            if [[ -n "$text" ]]; then
                echo "${PROGRAM_NAME}: multi-word strings must be enclosed in double quotes" >&2
                echo "Try '${PROGRAM_NAME} -s \"hello world\"'" >&2
                exit 1
            fi
            echo "${PROGRAM_NAME}: extra operand '$1'" >&2
            echo "Try '${PROGRAM_NAME} --help' for more information" >&2
            exit 1
            ;;
    esac
done

# --- VALIDATION ---
if [[ -z "$input_source" ]]; then
    echo "${PROGRAM_NAME}: no input source specified" >&2
    echo "Try '${PROGRAM_NAME} --help' for more information" >&2
    exit 1
fi

if [[ "$input_source" == "file" ]]; then
    if [[ ! -e "$file_name" ]]; then
        echo "${PROGRAM_NAME}: ${file_name}: No such file or directory" >&2
        exit 1
    elif [[ ! -f "$file_name" ]]; then
        echo "${PROGRAM_NAME}: ${file_name}: Not a regular file" >&2
        exit 1
    elif [[ ! -r "$file_name" ]]; then
        echo "${PROGRAM_NAME}: ${file_name}: Permission denied" >&2
        exit 1
    elif [[ $(file -b --mime-type "$file_name") != text/* ]]; then
        echo "${PROGRAM_NAME}: ${file_name}: Not a plaintext file" >&2
        exit 1
    fi
fi

# --- DATA EXTRACTION ---
case "$input_source" in
    clipboard)
        text="$(xsel -b)"
        ;;
    file)
        text="$(cat "$file_name")"
        ;;
    string)
        ;;
    *)
        echo "${PROGRAM_NAME}: invalid internal input configuration" >&2
        exit 1
        ;;
esac

# --- COMPONENT SETUP & TRACKING ---
mp3file=$(mktemp /tmp/mpv3_audio.XXXXXX.mp3)
wav_segment=$(mktemp /tmp/mpv3_seg.XXXXXX.wav)

# --- CLEAN EXIT & INTERRUPT TRAP ---
cleanup() {
    pkill -P $$ festival lame mpv 2>/dev/null
    rm -f "$mp3file" "$wav_segment" 2>/dev/null
}
trap 'cleanup; echo -e "\n[Playback Interrupted]"; exit 0' SIGINT SIGTERM
trap 'cleanup' EXIT

# --- AUDIO CAPTURE PIPELINE ---
# Parse text cleanly by grammatical sentences
printf '%s\n' "$text" | \
awk '
  BEGIN { RS="[ \t\n]+" } 
  { 
    printf "%s ", $0
    if ($0 ~ /[.?!]["\x27\x22]*$/) { printf "\n" }
  }
  END { printf "\n" }
' | \
while read -r sentence; do
    [[ -z "${sentence//[:space:]/}" ]] && continue

    # Safely handle quote escaping for Scheme parameter injection
    escaped_sentence=$(printf '%s' "$sentence" | sed 's/"/\\"/g')
    
    # Render individual segments cleanly to a temporary WAV container with strict pacing
    festival -b \
        "(Parameter.set 'Duration_Stretch 0.7)" \
        "(utt.save.wave (SayText \"$escaped_sentence\") \"$wav_segment\")" &>/dev/null

    # Append the uncompressed WAV chunk directly onto our tracking MP3 payload file
    if [[ -f "$wav_segment" && -s "$wav_segment" ]]; then
        lame --preset standard "$wav_segment" - >> "$mp3file" 2>/dev/null
        rm -f "$wav_segment"
    fi
done

# --- INTEGRITY FALLBACK VERIFICATION ---
if [[ ! -s "$mp3file" ]]; then
    echo "${PROGRAM_NAME}: audio generation failure (empty output)" >&2
    exit 1
fi

# --- MEDIA PLAYBACK ---
mpv "$mp3file"

# --- AUDIO INTERACTION PROMPT ---
if [[ -n "$file_name" ]]; then
    default_name="${file_name%.*}.mp3"
else
    default_name="output.mp3"
fi

while true; do
    read -n 1 -rp "Save MP3? [Y/n] " save_answer
    echo "" 

    case "$save_answer" in
        [Yy]*|"")
            read -rp "Filename (default: $default_name): " user_filename
            final_name="${user_filename:-$default_name}"

            [[ "$final_name" != *.mp3 ]] && final_name="${final_name}.mp3"
            
            mv "$mp3file" "$final_name"
            echo "Saved as ${final_name}"
            break
            ;;
        [Nn]*)
            echo "MP3 not saved"
            break
            ;;
        *)
            echo "${PROGRAM_NAME}: invalid input: please press Y or N" >&2
            ;;
    esac
done