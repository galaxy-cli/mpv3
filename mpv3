#!/usr/bin/env bash
#                         _____ 
#    _ __ ___  _ ____   _|___ / 
#   | '_ ` _ \| '_ \ \ / / |_ \ 
#   | | | | | | |_) \ V / ___) |
#   |_| |_| |_| .__/ \_/ |____/ 
#             |_|               
#
# mpv3 - Text-to-speech and playback utility using Festival, LAME, and MPV
#
# Project: https://github.com/galaxy-cli/mpv3

# Strict POSIX configuration
set -o errexit
set -o nounset
set -o pipefail

# Semantic Versioning
VERSION="1.0.1"

# Set up clean global paths
PROGRAM_NAME=$(basename "$0")
WORK_DIR=""

# Displays usage guidelines following POSIX standards
usage() {
    cat <<EOF
Usage: ${PROGRAM_NAME} [OPTIONS] <plaintext_file>

Convert a plaintext document into an MP3 at accelerated pacing and play it back.

Options:
  -v, --version    Display version information and exit
  -h, --help       Display this help message and exit

Dependencies:
  festival (text2wave), lame, mpv

Report bugs to: <207926666+galaxy-cli@://github.com>
EOF
    exit 0
}

# Displays version string compliant with Semantic Versioning 2.0.0
version() {
    echo "${PROGRAM_NAME} v${VERSION}"
    exit 0
}

# Error helper function
error_exit() {
    echo "mpv3: $1" >&2
    exit 1
}

# Automated workspace cleanup sequence
cleanup() {
    if [[ -n "${WORK_DIR}" && -d "${WORK_DIR}" ]]; then
        rm -rf "${WORK_DIR}"
    fi
}
trap cleanup EXIT INT TERM

# GNU/POSIX argument parsing transformation
# Translates double-dash options into single letters for standard getopts compatibility
for arg in "$@"; do
    shift
    case "$arg" in
        --help)    set -- "$@" "-h" ;;
        --version) set -- "$@" "-v" ;;
        *)         set -- "$@" "$arg" ;;
    esac
done

# Standard POSIX option loop
while getopts "hv" opt; do
    case "${opt}" in
        h) usage ;;
        v) version ;;
        *) usage ;;
    esac
done
shift $((OPTIND - 1))

# Check for the mandatory trailing operand
if [ "$#" -ne 1 ]; then
    echo "mpv3: missing required plaintext file operand." >&2
    echo "Try '${PROGRAM_NAME} --help' for more information." >&2
    exit 1
fi

TEXT_FILE="$1"

# Verify filesystem layout constraints
if [ ! -f "${TEXT_FILE}" ]; then
    error_exit "File '${TEXT_FILE}' not found or is not a regular file."
fi

# Verify program binaries are present in local environment paths
for cmd in text2wave lame mpv; do
    if ! command -v "${cmd}" &> /dev/null; then
        error_exit "Required binary dependency '${cmd}' is missing from PATH."
    fi
done

# Secure dynamic file layouts
WORK_DIR=$(mktemp -d)
TEMP_MP3="${WORK_DIR}/output.mp3"

echo "Processing text-to-speech with custom pacing..."

# Pipe the audio stream securely to the LAME pipeline
if ! text2wave -eval "(Parameter.set 'Duration_Stretch 0.7)" "${TEXT_FILE}" \
    | lame -m m -b 64 - "${TEMP_MP3}" &> /dev/null; then
    error_exit "TTS conversion or MP3 compression pipeline failed."
fi

# Verify structural media file density before initialization
if [ -s "${TEMP_MP3}" ]; then
    echo "Playing accelerated audio with mpv..."
    mpv "${TEMP_MP3}"
else
    error_exit "Generated audio file layout is empty or corrupted."
fi