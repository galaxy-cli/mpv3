#!/bin/bash
#                         _____ 
#    _ __ ___  _ ____   _|___ / 
#   | '_ ` _ \| '_ \ \ / / |_ \ 
#   | | | | | | |_) \ V / ___) |
#   |_| |_| |_| .__/ \_/ |____/ 
#             |_|               
#
# mpv3 - Text-to-speech and playback utility using Festival, LAME, and MPV
#
# Project: https://github.com/galaxy-cli/mpv3
# Requirements: festival, xsel, lame, mpv
#
# Description:
#   A lightweight CLI tool that converts text from strings, files, or the
#   clipboard into MP3 audio for instant playback and optional saving.

# --- DEPENDENCY CHECK ---
missing=()
for cmd in festival xsel lame mpv; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        missing+=("$cmd")
    fi
done

if [ "${#missing[@]}" -gt 0 ]; then
    echo "mpv3: error: The following dependencies are missing: ${missing[*]}" >&2
    read -rp "Would you like to install them via apt? [Y/n] " yn
    yn=${yn:-Y}

    if [[ $yn =~ ^[Yy]$ ]]; then
        sudo apt update && sudo apt install -y "${missing[@]}"
    else
        echo "mpv3: error: cannot continue without required dependencies" >&2
        exit 1
    fi
fi

# --- USAGE ---
usage() {
    cat <<EOF
USAGE
  mpv3 [OPTION]

DESCRIPTION
  A lightweight CLI utility that converts text from files, strings, or 
  the clipboard into MP3 audio for instant playback and saving

OPTIONS
  -c, --clipboard     Use clipboard (xsel)
  -f, --file FILE     Use specified text file
  -s, --speak TEXT    Speak the provided string
EOF
}

# --- INITIALIZE ---
input_source=""
file_name=""

# --- ARGUMENT PARSING ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --help)
            usage
            exit 1
            ;;
        -c|--clipboard)
            [[ -n "$input_source" ]] && { echo "mpv3: error: multiple input sources specified" >&2; exit 1; }
            input_source="clipboard"
            shift
            ;;
        -f|--file)
            [[ -n "$input_source" ]] && { echo "mpv3: error: multiple input sources specified" >&2; exit 1; }
            [[ -z "$2" || "$2" == -* ]] && { echo "mpv3: error: --file requires a filename" >&2; exit 1; }
            if [[ ! -f "$2" || ! -r "$2" ]]; then
                echo "mpv3: error: '$2' does not exist or is not readable" >&2
                exit 1
            elif ! file -b --mime-type "$2" | grep -q "^text/"; then
                echo "mpv3: error: '$2' is not a plaintext file (detected as $(file -b --mime-type "$2"))" >&2
                exit 1
            fi 
            input_source="file"
            file_name="$2"
            shift 2
            ;;
        -s|--speak)
            [[ -z "$2" || "$2" == -* ]] && { echo "mpv3: error: --speak requires a quoted string" >&2; exit 1; }
            if [[ -n "$3" && "$3" != -* ]]; then
                echo "mpv3: error: multi-word strings must be enclosed in double quotes" >&2
                echo "Example: mpv3 -s \"hello world\"" >&2
                exit 1
            fi
            input_source="string"
            text="$2"
            shift 2
            ;;
        *)
            echo "mpv3: error: unknown option '$1'" >&2
            echo "Try 'mpv3 --help' for more information" >&2
            exit 1
            ;;
    esac
done

# --- VALIDATION ---
if [[ -z "$input_source" ]]; then
    echo "mpv3: error: no input source specified" >&2
    echo "Try 'mpv3 --help' for more information" >&2
    exit 1
fi

# --- OPTION ---
if [[ -z "$text" ]]; then
    case "$input_source" in
        clipboard)
            text="$(xsel)"
            ;;
        file)
            text="$(cat "$file_name")"
            ;;
        string)
            ;;
        *)
            usage
            exit 1
            ;;
    esac
fi

# --- MPV3 FUNCTION ---
# 1. Create one temporary file for the text (since text2wave needs a file)
textfile=$(mktemp /tmp/mpv3_text.XXXXXX)
mp3file=$(mktemp /tmp/mpv3_audio.XXXXXX.mp3)

echo "$text" > "$textfile"

# 2. Pipe the WAVE output from text2wave directly into lame
# Use '-' for lame to read from stdin
text2wave -eval "(Parameter.set 'Duration_Stretch 0.7)" "$textfile" | \
lame -r -s 16 -m m - "$mp3file" &>/dev/null

# 3. Play the resulting MP3
mpv "$mp3file"


# --- MP3 SAVE PROMPT ---
# Define a default name based on the input, or use 'output.mp3'
default_name="${file_name%.*}.mp3"
default_name="${default_name:-output.mp3}"

if [[ "$2" != *.mp3 ]]; then
    while true; do

        # -n 1: reacts after 1 character. -p: prompt.
        read -n 1 -rp "Save MP3? [Y/n] " save_answer
        echo "" # Move to a new line after the keypress

        case "$save_answer" in
            [Yy]*|"")
                read -rp "Filename (default: $default_name): " user_filename

                # Use default if they just hit enter
                final_name="${user_filename:-$default_name}"

                # Ensure .mp3 extension
                [[ "$final_name" != *.mp3 ]] && final_name="${final_name}.mp3"
                mv "$mp3file" "$final_name"
                echo "Saved as $final_name"
                break
                ;;
            [Nn]*)
                echo "MP3 not saved"
                rm -f "$mp3file" # Clean up the temp file immediately
                break
                ;;
            *)
                echo "Please press Y or N"
                ;;
        esac
    done
fi